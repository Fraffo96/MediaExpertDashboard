# BigQuery + Firestore (opzione B, GCP reale) — stesso service account / stesso JSON
# Copia in .env e compila i valori.
#
# 1. Esegui: .\scripts\setup-bigquery-service-account.ps1
#    (assegna BigQuery + roles/datastore.user per Firestore; aggiorna .env e rimuove FIRESTORE_EMULATOR_HOST)
# 2. Se avevi gia' creato il SA solo per BigQuery: .\scripts\grant-firestore-to-dashboard-sa.ps1
# 3. Database Firestore nel progetto: .\scripts\provision-firestore-and-brand-logos.ps1 (una tantum)
# 4. NON impostare FIRESTORE_EMULATOR_HOST per usare Firestore nel cloud (opzione B).

GCP_PROJECT_ID=mediaexpertdashboard
GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\tuo-service-account.json

# Firestore — solo per emulatore locale (opzione A). Per opzione B lasciare commentato / assente.
# FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
# FIRESTORE_DATABASE=
# Se non impostato, il client usa il database default "(default)".

# Loghi brand — URL pubblico GCS del bucket (senza slash finale), stesso di Cloud Run / cloudbuild.
# Se assente: si usa GCP_PROJECT_ID per `https://storage.googleapis.com/<id>-brand-logos/brands`,
# altrimenti la costante DEFAULT_GCS_BRAND_LOGOS_BASE in app/constants.py.
BRAND_LOGOS_PUBLIC_BASE=https://storage.googleapis.com/mediaexpertdashboard-brand-logos/brands
#
# Topbar: stesso schema Cloud Run — img src = HTTPS verso questo bucket (i PNG non sono su Firestore, solo brand_id utente).
# Eccezione: forzare path same-origin /brand-logo/<id>.png (proxy httpx → GCS), raro:
# BRAND_LOGOS_FORCE_SAME_ORIGIN_IMG=1
#
# Il proxy /brand-logo/ resta per fallback o debug. Se solo il proxy fallisce (502): HTTP_PROXY/HTTPS_PROXY per Python.
#
# Opzionale: cache-bust browser (es. git SHA)
# BRAND_LOGOS_CACHE_VERSION=
#
# Se un utente ha role=admin ma nessun brand_id in Firestore, la topbar usa comunque un logo:
# default brand_id=1 (log in WARNING). Override esplicito o disattiva con 0:
# BRAND_LOGO_FALLBACK_BRAND_ID=1

# Auth - OBBLIGATORIO in produzione (Cloud Run, ecc.)
# Genera una chiave sicura: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=mediaexpert-dashboard-secret-change-in-prod

# Cache Redis (consigliato su Cloud Run con Memorystore — persiste tra richieste e riavvii istanza)
# Senza Redis: cache solo in RAM (max durata = uptime del processo).
# Con REDIS_URL impostato, i default sono ~24h (CACHE_TTL_SECONDS) e ~7gg (CACHE_TTL_LONG per all-years).
# REDIS_URL=redis://10.0.0.3:6379
# CACHE_TTL_SECONDS=86400
# CACHE_TTL_LONG_SECONDS=604800
#
# Svuotamento totale Redis da admin (POST /api/admin/clear-cache con JSON {"flush_redis_db": true}):
# abilita solo su istanza Memorystore dedicata alla dashboard (FLUSHDB). Default disattivo.
# ENABLE_ADMIN_REDIS_FLUSHDB=1

# Pre-warming: token per Cloud Scheduler (opzionale)
# Genera: python -c "import secrets; print(secrets.token_urlsafe(32))"
# PREWARM_TOKEN=
# Brand da riscaldare senza leggere Firestore (CSV). Utile dopo clear-cache.
# PREWARM_BRAND_IDS=1,2,8
# Locale: python scripts/run_prewarm.ps1 | Cloud: curl -H "X-Prewarm-Token: …" "https://<host>/internal/prewarm"

# Pipeline dati lunga (Cloud Run Job). Nome job in GCP; la dashboard invoca RunJob con override env.
# CLOUD_RUN_DATA_JOB_NAME=dashboard-data-pipeline
# GCP_REGION=europe-west1
# Opzionale (worker / script): SEED_NUM_ORDERS, SEED_NUM_CUSTOMERS, SEED_NUM_PRODUCTS
